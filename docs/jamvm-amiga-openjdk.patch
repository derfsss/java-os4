+/* VM exit (AmigaOS): clib4 exit() waits for ALL pthread children, so any Java
+   thread still alive when the exiting thread calls exit() wedges the process
+   ("Parent suspended, waiting for child to exit").  exitWakeAllThreads()
+   (called from terminateVMThreads) interrupts every thread out of
+   Object.wait/sleep; back in the dispatch loop they hit this poll and
+   self-terminate.  Only the thread-list/count bookkeeping is updated --
+   Java-level state no longer matters, but threads_count must drain so
+   amiga_exit knows when it is safe to call exit(). */
+extern volatile int vm_exiting;
+static Thread *vm_exit_thread = NULL;
+
+void exitWakeAllThreads() {
+    static int gate_opened = FALSE;
+    Thread *self = threadSelf();
+    Thread *thread;
+
+    vm_exit_thread = self;
+    /* the dispatch-loop poll (THREAD_POLL_SUSPEND) is gated on
+       suspend_pending_count -- open the gate permanently so every thread
+       still executing bytecode reaches threadPollSuspend and dies there */
+    if(!gate_opened) {
+        gate_opened = TRUE;
+        suspend_pending_count++;
+    }
+    MBARRIER();
+
+    pthread_mutex_lock(&lock);
+    for(thread = &main_thread; thread != NULL; thread = thread->next)
+        if(thread != self)
+            threadInterrupt(thread);
+    pthread_mutex_unlock(&lock);
+}
+
+/* diagnostic: name+state of every thread still attached (exit-wedge hunts) */
+void exitDumpRemainingThreads() {
+    Thread *thread;
+    char buffer[80];
+
+    pthread_mutex_lock(&lock);
+    for(thread = &main_thread; thread != NULL; thread = thread->next) {
+        classlibThreadName2Buff(thread->ee->thread, buffer, sizeof(buffer));
+        jam_fprintf(stderr, "[EXIT]   live thread \"%s\" state=%s\n",
+                    buffer, getThreadStateString(thread));
+    }
+    pthread_mutex_unlock(&lock);
+}
+
+static void exitDetachAndDie(Thread *thread) {
+    pthread_mutex_lock(&lock);
+    if((thread->prev->next = thread->next))
+        thread->next->prev = thread->prev;
+    threads_count--;
+    pthread_mutex_unlock(&lock);
+    pthread_exit(NULL);
+}
+
 void threadPollSuspend() {
     Thread *thread = threadSelf();
 
+    if(vm_exiting && thread != NULL && thread != vm_exit_thread
+                  && thread != &main_thread)
+        exitDetachAndDie(thread);
+
     if(thread != NULL && thread->suspend
                       && thread->suspend_state == SUSP_NONE)
         suspendLoop(thread);
