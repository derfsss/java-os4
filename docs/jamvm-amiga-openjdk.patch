+
+#include <proto/exec.h>
+#include <proto/dos.h>
+#include <dos/dos.h>
+
+/* JamVM's per-platform init hook (called from src/init.c:initVM).
+ *
+ * clib4's pthread_create() duplicates the parent's Input(), Output() and
+ * ErrorOutput() DOS streams for every new thread and FAILS with EAGAIN if any
+ * of them is unset (DupFileHandle(0) fails).  When JamVM is launched
+ * non-interactively (e.g. via the mcpd test harness) the error and/or input
+ * streams can be NULL, so the very first createVMThread() would deadlock.
+ * Ensure all three streams are valid before any thread is created. */
+void initialisePlatform() {
+    if(ErrorOutput() == 0)
+        SelectErrorOutput(Output());
+
+    if(Input() == 0) {
+        BPTR nil = Open("NIL:", MODE_OLDFILE);
+        if(nil != 0)
+            SelectInput(nil);
+    }
+
+    if(Output() == 0) {
+        BPTR nil = Open("NIL:", MODE_NEWFILE);
+        if(nil != 0)
+            SelectOutput(nil);
+    }
+
+    /* Re-point error output once more in case Output() was just created. */
+    if(ErrorOutput() == 0)
