From 416f0e4d756e8a94ac74c1718b8edb6ea4dcaf9b Mon Sep 17 00:00:00 2001
From: Richard Gibbs <wofderfs@googlemail.com>
Date: Wed, 10 Jun 2026 08:00:59 +0100
Subject: [PATCH 04/10] properties.c: present user.dir as Unix-absolute
 ("/Volume:dir") on AmigaOS

Part of the Amiga path model: java.io/java.nio see '/'-prefixed absolute paths
(File.isAbsolute()/toURI()/sun.nio.fs.UnixFileSystem all require it; without
this UnixFileSystem rejects user.dir and File.getAbsolutePath() doubles paths),
and the native open/stat chokepoints strip the '/' back off.  With the
niopatch.zip bootclasspath prepend + -Dsun.nio.fs.chdirAllowed=true this makes
full `java -classpath` (URLClassLoader) work on AmigaOS.

Co-Authored-By: Claude Opus 4.8 <noreply@anthropic.com>
---
 src/properties.c | 16 ++++++++++++++++
 1 file changed, 16 insertions(+)

diff --git a/src/properties.c b/src/properties.c
index b453d7b..19169ff 100644
--- a/src/properties.c
+++ b/src/properties.c
@@ -152,6 +152,22 @@ char *getExecutionEngineName() {
 void setUserDirProperty(Object *properties) {
     char *cwd = getCwd();
 
+#ifdef __amigaos4__
+    /* Present user.dir as Unix-absolute ("/Volume:dir") -- part of the Amiga
+       path model: java.io/java.nio see '/'-prefixed absolute paths (so
+       File.isAbsolute()/toURI()/UnixFileSystem don't mis-handle "Volume:"),
+       and the native open/stat chokepoints strip the '/' back off.  Without
+       this, sun.nio.fs.UnixFileSystem rejects user.dir ("default directory
+       must be absolute") and File.getAbsolutePath() doubles paths. */
+    if(cwd != NULL && cwd[0] != '/') {
+        char *slashed = sysMalloc(strlen(cwd) + 2);
+        slashed[0] = '/';
+        strcpy(slashed + 1, cwd);
+        sysFree(cwd);
+        cwd = slashed;
+    }
+#endif
+
     setProperty(properties, "user.dir", cwd);
     sysFree(cwd);
 }
-- 
